{
  "manifest_version": 3,
  "name": "SongSelect Cookie Sync",
  "version": "1.0.0",
  "description": "Automatically syncs your SongSelect session to your church app for chord chart imports",
  "permissions": ["cookies", "storage", "alarms"],
  "host_permissions": ["https://*.ccli.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "SongSelect Cookie Sync"
  }
}
