# New Admin - Analytics App
RewriteRule ^adminnew/analytics/?$ adminnew/index.php?module=analytics [L,QSA]
RewriteRule ^adminnew/analytics/([a-zA-Z0-9-]+)/?$ adminnew/index.php?module=analytics&page=$1 [L,QSA]

# New Admin - Website App
RewriteRule ^adminnew/website/?$ adminnew/index.php?module=website [L,QSA]
RewriteRule ^adminnew/pages/?$ adminnew/index.php?module=pages [L,QSA]
RewriteRule ^adminnew/pages/([a-zA-Z0-9-]+)/?$ adminnew/index.php?module=pages&page=$1 [L,QSA]
RewriteRule ^adminnew/blog/?$ adminnew/index.php?module=blog [L,QSA]
RewriteRule ^adminnew/blog/([a-zA-Z0-9-]+)/?$ adminnew/index.php?module=blog&page=$1 [L,QSA]
