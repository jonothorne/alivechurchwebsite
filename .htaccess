# Enable Rewrite Engine
RewriteEngine On
RewriteBase /

# === PHP UPLOAD LIMITS ===
# Increase limits for large file uploads (may not work with PHP-FPM)
<IfModule mod_php.c>
    php_value upload_max_filesize 256M
    php_value post_max_size 512M
    php_value max_execution_time 600
    php_value max_input_time 600
    php_value memory_limit 512M
</IfModule>

# Disable automatic directory slash redirect (prevents /www/ exposure)
DirectorySlash Off

# === WEBP AUTO-SERVING ===
# Serve WebP images automatically when browser supports it and WebP version exists
# This allows URLs to stay as .jpg/.png but serve the smaller WebP file
<IfModule mod_rewrite.c>
    RewriteCond %{HTTP_ACCEPT} image/webp
    RewriteCond %{REQUEST_URI} \.(jpe?g|png)$
    RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI}.webp -f
    RewriteRule ^(.+)\.(jpe?g|png)$ $1.$2.webp [T=image/webp,L]
</IfModule>

# Alternative: Check for WebP file with same base name (image.jpg -> image.webp)
<IfModule mod_rewrite.c>
    RewriteCond %{HTTP_ACCEPT} image/webp
    RewriteCond %{REQUEST_URI} ^(.+)\.(jpe?g|png)$
    RewriteCond %{DOCUMENT_ROOT}%1.webp -f
    RewriteRule ^(.+)\.(jpe?g|png)$ $1.webp [T=image/webp,L]
</IfModule>

# Ensure correct content type for WebP
<IfModule mod_headers.c>
    <FilesMatch "\.(webp)$">
        Header set Content-Type "image/webp"
    </FilesMatch>
</IfModule>

# Add Vary header so CDNs/proxies cache both versions
<IfModule mod_headers.c>
    <FilesMatch "\.(jpe?g|png)$">
        Header append Vary Accept
    </FilesMatch>
</IfModule>
# === END WEBP AUTO-SERVING ===

# === BIBLE STUDY QUESTIONS (priority route) ===
RewriteRule ^bible-study/questions/?$ bible-study-questions.php [L,QSA]
RewriteRule ^bible-study/questions/([a-zA-Z0-9-]+)/?$ bible-study-question.php?question=$1 [L,QSA]

# === API ROUTES (must come first to avoid redirect issues) ===
# Route API calls without .php extension to their .php files
RewriteRule ^api/cms/save$ api/cms/save.php [L,QSA]
RewriteRule ^api/cms/upload$ api/cms/upload.php [L,QSA]
RewriteRule ^api/cms/media$ api/cms/media.php [L,QSA]
RewriteRule ^api/cms/page$ api/cms/page.php [L,QSA]
RewriteRule ^api/cms/blocks$ api/cms/blocks.php [L,QSA]
RewriteRule ^api/bible-study/save$ api/bible-study/save.php [L,QSA]
RewriteRule ^api/user-preferences$ api/user-preferences.php [L,QSA]
RewriteRule ^api/cookie-consent$ api/cookie-consent.php [L,QSA]
RewriteRule ^api/newsletter-signup$ api/newsletter-signup.php [L,QSA]
RewriteRule ^api/user-studies$ api/user-studies.php [L,QSA]
RewriteRule ^api/question-search$ api/question-search.php [L,QSA]
RewriteRule ^api/process-donation$ api/process-donation.php [L,QSA]
RewriteRule ^api/process-donation\.php$ api/process-donation.php [L,QSA]
# === END API ROUTES ===

# Sitemap - serve sitemap.xml from sitemap.php
RewriteRule ^sitemap\.xml$ sitemap.php [L]

# Author/User profile pages - rewrite to author.php with username parameter
RewriteRule ^author/([^/]+)/?$ author.php?username=$1 [L,QSA]
RewriteRule ^user/([^/]+)/?$ author.php?username=$1 [L,QSA]

