RewriteRule ^admin/api/tag-media/?$ admin/api/tag-media.php [L,QSA]
RewriteRule ^admin/api/rotate-media/?$ admin/api/rotate-media.php [L,QSA]

# Music Stand PWA - route all requests to its index.php
RewriteRule ^musicstand/?$ musicstand/index.php [L,QSA]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^musicstand/(.+)$ musicstand/index.php [L,QSA]

# My Studies pages
RewriteRule ^my-studies/?$ my-studies.php [L,QSA]
RewriteRule ^my-studies/saved/?$ my-studies-saved.php [L,QSA]
RewriteRule ^my-studies/highlights/?$ my-studies-highlights.php [L,QSA]
RewriteRule ^my-studies/history/?$ my-studies-history.php [L,QSA]

# === END DIRECTORY ROUTES ===

# Force HTTPS in production
RewriteCond %{HTTPS} off
RewriteCond %{HTTP_HOST} !^localhost [NC]
RewriteCond %{HTTP_HOST} !\.test$ [NC]
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Remove trailing slashes (except for directories)
# Use THE_REQUEST to get the original URL (not internally rewritten)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{THE_REQUEST} \s(.+?)/\s [NC]
RewriteRule ^ %1 [R=301,L]

# Remove .php extension if it exists in the URL (except for API endpoints)
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s([^.]+)\.php [NC]
RewriteCond %{REQUEST_URI} !^/api/ [NC]
RewriteCond %{REQUEST_URI} !^/admin/api/ [NC]
RewriteRule ^ %1 [R=301,L]

# Sermon pages
# /sermon/sermon-slug -> sermon.php?slug=sermon-slug
RewriteRule ^sermon/([a-zA-Z0-9-]+)/?$ sermon.php?slug=$1 [L,QSA]

# Sermon series pages
# /sermons/series/series-slug -> sermon-series.php?slug=series-slug
RewriteRule ^sermons/series/([a-zA-Z0-9-]+)/?$ sermon-series.php?slug=$1 [L,QSA]

# Sermon sub-pages
RewriteRule ^sermons/series/?$ sermons/series.php [L,QSA]
RewriteRule ^sermons/speakers/?$ sermons/speakers.php [L,QSA]
RewriteRule ^sermons/topics/?$ sermons/topics.php [L,QSA]

# About index page
RewriteRule ^about/?$ about.php [L,QSA]

# About sub-pages
RewriteRule ^about/history/?$ about/history.php [L,QSA]
RewriteRule ^about/what-we-believe/?$ about/what-we-believe.php [L,QSA]
RewriteRule ^about/vision/?$ about/vision.php [L,QSA]
RewriteRule ^about/dead-church/?$ about/dead-church.php [L,QSA]
RewriteRule ^youth/?$ about/youth.php [L,QSA]

# Bible study sub-pages (must come before book rule)
RewriteRule ^bible-study/topics/?$ bible-study-topics.php [L,QSA]
RewriteRule ^bible-study/topics/([a-zA-Z0-9-]+)/?$ bible-study-topic.php?topic=$1 [L,QSA]
RewriteRule ^bible-study/search/?$ bible-study-search.php [L,QSA]

# Bible study chapter pages
# /bible-study/psalms/5 -> bible-study-chapter.php?book=psalms&chapter=5
RewriteRule ^bible-study/([a-zA-Z0-9-]+)/([0-9]+)/?$ bible-study-chapter.php?book=$1&chapter=$2 [L,QSA]

# Bible study book pages (must come after chapter rule and sub-pages)
# /bible-study/psalms -> bible-study-book.php?book=psalms
RewriteRule ^bible-study/([a-zA-Z0-9-]+)/?$ bible-study-book.php?book=$1 [L,QSA]

# Blog post pages
# /blog/post-slug -> blog-post.php?slug=post-slug
RewriteRule ^blog/([a-zA-Z0-9-]+)/?$ blog-post.php?slug=$1 [L,QSA]

# Testimonies/Stories page
RewriteRule ^testimonies/?$ testimonies.php [L,QSA]

# Next Steps page
RewriteRule ^next-steps/?$ next-steps.php [L,QSA]

# Reading plans
RewriteRule ^reading-plans/?$ reading-plans.php [L,QSA]

# Individual reading plan pages (singular URL pattern used by PHP code)
RewriteRule ^reading-plan/([a-zA-Z0-9-]+)/day/([0-9]+)/?$ reading-plan-day.php?plan=$1&day=$2 [L,QSA]
RewriteRule ^reading-plan/([a-zA-Z0-9-]+)/?$ reading-plan-view.php?plan=$1 [L,QSA]

# Sermons browse page (already handled by generic routing to sermons.php)

# Route clean URLs to .php files
# First check if the actual file exists
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} !^/author/
RewriteCond %{REQUEST_URI} !^/user/
RewriteCond %{REQUEST_URI} !^/sermon/
RewriteCond %{REQUEST_URI} !^/sermons/series/

# Check if adding .php makes it a valid file
RewriteCond %{REQUEST_FILENAME}.php -f [OR]
RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI}.php -f

# Rewrite to .php file
RewriteRule ^(.*)$ $1.php [L,QSA]

# Fallback: Route all other requests to page.php (CMS dynamic pages)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} !^/author/
RewriteCond %{REQUEST_URI} !^/user/
RewriteCond %{REQUEST_URI} !^/sermon/
RewriteCond %{REQUEST_URI} !^/sermons/series/
RewriteRule ^(.*)$ page.php [L,QSA]

# Custom error pages (optional)
ErrorDocument 404 /404.php

# Prevent directory browsing
Options -Indexes

# Security headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"

    # HSTS - enforce HTTPS for 1 year, include subdomains
    Header set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

    # Content Security Policy is set dynamically via PHP (includes/bootstrap.php)
    # to support nonce-based script/style validation instead of unsafe-inline
</IfModule>

# Hide PHP version (also set expose_php = Off in php.ini on server)
<IfModule mod_headers.c>
    Header unset X-Powered-By
</IfModule>
php_flag expose_php Off

# Compression (optional - improves performance)
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

# Browser caching - improves performance significantly
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 1 month"

    # Images - cache for 1 year
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresByType image/vnd.microsoft.icon "access plus 1 year"

    # Fonts - cache for 1 year
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType application/font-woff "access plus 1 year"
    ExpiresByType application/font-woff2 "access plus 1 year"

    # CSS and JavaScript - cache for 1 month (uses cache-busting query strings)
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType text/javascript "access plus 1 month"

    # Documents
    ExpiresByType application/pdf "access plus 1 month"

    # HTML - short cache for dynamic content
    ExpiresByType text/html "access plus 0 seconds"

    # JSON/XML API responses
    ExpiresByType application/json "access plus 0 seconds"
    ExpiresByType application/xml "access plus 0 seconds"

    # Web manifest
    ExpiresByType application/manifest+json "access plus 1 week"
</IfModule>

# Cache-Control headers for better browser caching
<IfModule mod_headers.c>
    # Static assets - immutable when versioned
    <FilesMatch "\.(ico|pdf|flv|jpg|jpeg|png|gif|webp|svg|js|css|swf|woff|woff2)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    # HTML - no cache (dynamic content)
    <FilesMatch "\.(html|htm|php)$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
    </FilesMatch>
</IfModule>
