RewriteRule ^adminnew/sermons/([a-zA-Z0-9-]+)/?$ adminnew/index.php?module=sermons&page=$1 [L,QSA]
RewriteRule ^adminnew/media/?$ adminnew/index.php?module=media [L,QSA]
RewriteRule ^adminnew/forms/?$ adminnew/index.php?module=forms [L,QSA]
RewriteRule ^adminnew/navigation/?$ adminnew/index.php?module=navigation [L,QSA]
RewriteRule ^adminnew/settings/?$ adminnew/index.php?module=settings [L,QSA]
RewriteRule ^adminnew/users/?$ adminnew/index.php?module=users [L,QSA]
RewriteRule ^adminnew/bible-study/?$ adminnew/index.php?module=bible-study [L,QSA]
RewriteRule ^adminnew/bible-study/([a-zA-Z0-9-]+)/?$ adminnew/index.php?module=bible-study&page=$1 [L,QSA]
RewriteRule ^adminnew/reading-plans/?$ adminnew/index.php?module=reading-plans [L,QSA]
RewriteRule ^adminnew/reading-plans/([a-zA-Z0-9-]+)/?$ adminnew/index.php?module=reading-plans&page=$1 [L,QSA]
RewriteRule ^adminnew/ministries/?$ adminnew/index.php?module=ministries [L,QSA]
RewriteRule ^adminnew/testimonies/?$ adminnew/index.php?module=testimonies [L,QSA]
RewriteRule ^adminnew/newsletter/?$ adminnew/index.php?module=newsletter [L,QSA]
RewriteRule ^adminnew/welcome-journeys/?$ adminnew/index.php?module=welcome-journeys [L,QSA]
RewriteRule ^adminnew/profanity-filter/?$ adminnew/index.php?module=profanity-filter [L,QSA]

# New Admin - People App
RewriteRule ^adminnew/people/?$ adminnew/index.php?module=people [L,QSA]
RewriteRule ^adminnew/people/([a-zA-Z0-9-]+)/?$ adminnew/index.php?module=people&page=$1 [L,QSA]

# New Admin - Generic module catch-all (must be last)
RewriteRule ^adminnew/([a-zA-Z0-9-]+)/?$ adminnew/index.php?module=$1 [L,QSA]
RewriteRule ^adminnew/([a-zA-Z0-9-]+)/([a-zA-Z0-9-]+)/?$ adminnew/index.php?module=$1&page=$2 [L,QSA]

# Admin Analytics sub-pages
RewriteRule ^admin/analytics/traffic/?$ admin/analytics/traffic.php [L,QSA]
RewriteRule ^admin/analytics/geographic/?$ admin/analytics/geographic.php [L,QSA]
