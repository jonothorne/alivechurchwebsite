RewriteRule ^admin/analytics/seo/?$ admin/analytics/seo.php [L,QSA]
RewriteRule ^admin/analytics/landing-pages/?$ admin/analytics/landing-pages.php [L,QSA]
RewriteRule ^admin/analytics/404s/?$ admin/analytics/404s.php [L,QSA]
RewriteRule ^admin/analytics/trends/?$ admin/analytics/trends.php [L,QSA]
RewriteRule ^admin/analytics/referrers/?$ admin/analytics/referrers.php [L,QSA]
RewriteRule ^admin/analytics/googlebot/?$ admin/analytics/googlebot.php [L,QSA]
